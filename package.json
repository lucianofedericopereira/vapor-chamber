{
  "name": "vapor-chamber",
  "version": "1.7.0",
  "description": "Lightweight command bus for Vue Vapor - plugins, hooks, undo/redo, Vue 3.6 Vapor aligned",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transports": {
      "import": "./dist/transports.js",
      "types": "./dist/transports.d.ts"
    },
    "./directives": {
      "import": "./dist/directives.js",
      "types": "./dist/directives.d.ts"
    },
    "./vite": {
      "import": "./dist/vite-hmr.js",
      "types": "./dist/vite-hmr.d.ts"
    },
    "./transitions": {
      "import": "./dist/transitions.js",
      "types": "./dist/transitions.d.ts"
    },
    "./ssr": {
      "import": "./dist/ssr.js",
      "types": "./dist/ssr.d.ts"
    },
    "./fast-lane": {
      "import": "./dist/fast-lane.js",
      "types": "./dist/fast-lane.d.ts"
    },
    "./observable": {
      "import": "./dist/observable.js",
      "types": "./dist/observable.d.ts"
    },
    "./standard-schema": {
      "import": "./dist/plugins-schema.js",
      "types": "./dist/plugins-schema.d.ts"
    },
    "./alien-signals": {
      "import": "./dist/alien-signals.js",
      "types": "./dist/alien-signals.d.ts"
    },
    "./reactive": {
      "import": "./dist/reactive.js",
      "types": "./dist/reactive.d.ts"
    },
    "./iife": {
      "import": "./dist/iife.js",
      "types": "./dist/iife.d.ts"
    },
    "./iife-core": {
      "import": "./dist/iife-core.js",
      "types": "./dist/iife-core.d.ts"
    },
    "./iife-elements": {
      "import": "./dist/iife-elements.js",
      "types": "./dist/iife-elements.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "scripts",
    "ROADMAP.md"
  ],
  "sideEffects": false,
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc && node scripts/build.mjs",
    "build:types": "tsc",
    "build:js": "node scripts/build.mjs",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write src tests scripts",
    "lint:check": "biome check src tests scripts",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run tests/perf.bench.ts",
    "size:check": "node scripts/check-size.mjs",
    "size": "node scripts/measure-size.mjs",
    "size:doc": "node scripts/measure-size.mjs --md > docs/BUNDLE-SIZES.md",
    "loc": "node scripts/measure-loc.mjs src",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "prepublishOnly": "npm run typecheck && npm run lint:check && npm run test:run && npm run build && npm run size:check"
  },
  "keywords": [
    "vue",
    "vapor",
    "vue-vapor",
    "command-bus",
    "commands",
    "plugins",
    "middleware",
    "undo-redo",
    "state-management",
    "signals",
    "reactive",
    "alien-signals",
    "vue-3.6",
    "vapor-mode"
  ],
  "author": "Luciano Federico Pereira",
  "license": "LGPL-2.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucianofedericopereira/vapor-chamber.git"
  },
  "bugs": {
    "url": "https://github.com/lucianofedericopereira/vapor-chamber/issues"
  },
  "homepage": "https://github.com/lucianofedericopereira/vapor-chamber#readme",
  "peerDependencies": {
    "@vitejs/plugin-vue": ">=5.0.0",
    "@vue/devtools-api": ">=6.0.0",
    "vite": ">=7.0.0",
    "vue": ">=3.5.0 || >=3.6.0-beta.16"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "@vue/devtools-api": {
      "optional": true
    },
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "alien-signals": "^3.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eventemitter3": "^5.0.4",
    "mitt": "^3.0.1",
    "nanoevents": "^9.1.0",
    "rxjs": "^7.8.2",
    "tiny-emitter": "^2.1.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.9",
    "vue": "^3.6.0-beta.16"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
