{
  "name": "vapor-chamber",
  "version": "0.5.0",
  "description": "Lightweight command bus for Vue Vapor - plugins, hooks, undo/redo, Vue 3.6 Vapor aligned",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transports": {
      "import": "./dist/transports.js",
      "types": "./dist/transports.d.ts"
    },
    "./directives": {
      "import": "./dist/directives.js",
      "types": "./dist/directives.d.ts"
    },
    "./vite": {
      "import": "./dist/vite-hmr.js",
      "types": "./dist/vite-hmr.d.ts"
    },
    "./iife": {
      "import": "./dist/iife.js",
      "types": "./dist/iife.d.ts"
    }
  },
  "files": [
    "dist",
    "scripts"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc && node scripts/build-iife.mjs",
    "build:esm": "tsc",
    "build:iife": "node scripts/build-iife.mjs",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm run test:run"
  },
  "keywords": [
    "vue",
    "vapor",
    "vue-vapor",
    "command-bus",
    "commands",
    "plugins",
    "middleware",
    "undo-redo",
    "state-management",
    "signals",
    "reactive",
    "alien-signals",
    "vue-3.6",
    "vapor-mode"
  ],
  "author": "Luciano Federico Pereira",
  "license": "LGPL-2.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucianofedericopereira/vapor-chamber.git"
  },
  "bugs": {
    "url": "https://github.com/lucianofedericopereira/vapor-chamber/issues"
  },
  "homepage": "https://github.com/lucianofedericopereira/vapor-chamber#readme",
  "peerDependencies": {
    "@vue/devtools-api": ">=6.0.0",
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "@vue/devtools-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
