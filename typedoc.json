{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/index.ts",
    "src/transports.ts",
    "src/directives.ts",
    "src/transitions.ts",
    "src/ssr.ts",
    "src/vite-hmr.ts"
  ],
  "out": "docs/api",
  "name": "vapor-chamber API reference",
  "readme": "README.md",
  "tsconfig": "tsconfig.json",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "includeVersion": true,
  "githubPages": true,
  "intentionallyNotExported": [
    "PayloadOf",
    "TargetOf",
    "ResultOf",
    "DispatchOptions",
    "CircuitState",
    "CsrfResult",
    "ErrorEntry",
    "InferFields",
    "Observable",
    "SchemaLoggerOptions"
  ],
  "navigationLinks": {
    "Repo": "https://github.com/lucianofedericopereira/vapor-chamber",
    "Performance": "https://github.com/lucianofedericopereira/vapor-chamber/blob/main/docs/performance.md",
    "Roadmap": "https://github.com/lucianofedericopereira/vapor-chamber/blob/main/ROADMAP.md",
    "Laravel integration": "https://github.com/lucianofedericopereira/vapor-chamber/blob/main/docs/integrations/laravel.md"
  },
  "sort": ["source-order"],
  "categorizeByGroup": true,
  "groupOrder": [
    "Functions",
    "Classes",
    "Interfaces",
    "Type Aliases",
    "Variables",
    "*"
  ],
  "highlightLanguages": [
    "typescript",
    "javascript",
    "json",
    "html",
    "bash",
    "shell",
    "css",
    "vue",
    "diff",
    "yaml",
    "php"
  ]
}
